{
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": "./src",                          /* Specify the root directory of input files */
    "outDir": "./dist",  
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "types": ["node"],
  "include": ["src"],
  "exclude": ["node_modules","dist"]
}